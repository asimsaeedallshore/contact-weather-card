
  {
  "uid": "contact_weather_card_app",
  "type": "app",
  "config": {
    "description": "An example to demonstrate how to build a static private app with developer projects that integrates real-time weather data.",
    "name": "contact-weather-card-App",
    "distribution": "private",
    "auth": {
      "type": "static",
      "requiredScopes": [
        "crm.objects.contacts.read",
        "crm.objects.contacts.write"
      ],
      "optionalScopes": [],
      "conditionallyRequiredScopes": []
    },
    "permittedUrls": {
      "fetch": [
        "https://api.hubapi.com",
        "https://api.openweathermap.org",
        "https://api.open-meteo.com",
        "https://api.weather.gov",
        "https://api.weatherapi.com"
       
      ],
      "iframe": [],
      "img": [
        "https://openweathermap.org",
        "https://cdn.weatherapi.com"
      ]
    },
    "support": {
      "supportEmail": "support@example.com",
      "documentationUrl": "https://example.com/docs",
      "supportUrl": "https://example.com/support",
      "supportPhone": "+18005555555"
    }
  }
}